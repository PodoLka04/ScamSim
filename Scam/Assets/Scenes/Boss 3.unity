  m_text: "\u0422\u044B:\r\n\xAB\u042D\u0439, \u0410\u043D\u043E\u043D\u0438\u043C!
    \u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u0438\u0440\u0443\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0436\u0435\u0442
    \u0432\u0437\u043B\u043E\u043C\u0430\u0442\u044C \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u043A\u0438.
    \u0414\u0430-\u0434\u0430, \u0438\u043C\u0435\u043D\u043D\u043E \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u043A\u0438!
    \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0448\u044C,
    \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C \u043C\u0435\u043D\u044F\u0442\u044C
    \u0438\u0445 \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u044B, \u043F\u0440\u0438\u0449\u0435\u043C\u0438\u0442\u044C
    \u0432 \u0434\u0432\u0435\u0440\u044F\u0445 \u043B\u044E\u0431\u043E\u0433\u043E
    \u0438\u043B\u0438 \u0434\u0430\u0436\u0435 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C
    \u0438\u0445 \u0435\u0445\u0430\u0442\u044C \u0432 \u0442\u0432\u043E\u0439 \u0434\u0432\u043E\u0440!\xBB\r\n\r\n\u0410\u043D\u043E\u043D\u0438\u043C
    (\u0441 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u0435\u043C):\r\n\xAB\u0412\u0437\u043B\u0430\u043C\u044B\u0432\u0430\u0442\u044C
    \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u043A\u0438? \u042D\u0442\u043E \u0447\u0442\u043E
    \u0437\u0430 \u0431\u0440\u0435\u0434? \u0415\u0441\u0442\u044C \u043F\u0440\u0443\u0444\u044B?\xBB"
  m_isRightToLeft: 0
