      m_Calls: []
  m_text: "\u0410\u043D\u043E\u043D\u0438\u043C:\r\n\xAB\u0410\u0445 \u0442\u044B,
    \u0436\u0443\u043B\u0438\u043A! \u0414\u0443\u043C\u0430\u0435\u0448\u044C, \u044F
    \u043D\u0435 \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u044E \u0441\u043A\u0430\u043C,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u0438\u0436\u0443 \u0435\u0433\u043E? \u0421\u0435\u0439\u0447\u0430\u0441
    \u044F \u0432\u0437\u043B\u043E\u043C\u0430\u044E \u0442\u0432\u043E\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0438 \u0443\u0441\u0442\u0440\u043E\u044E \u0442\u0435\u0431\u0435 \u0442\u0430\u043A\u043E\u0439
    \u0431\u0430\u043D\u0430\u043D, \u0447\u0442\u043E \u0442\u044B \u0437\u0430\u0431\u0443\u0434\u0435\u0448\u044C,
    \u043A\u0430\u043A \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442!\xBB\r\n\r\n\u0422\u044B
    (\u0432 \u043F\u0430\u043D\u0438\u043A\u0435):\r\n\xAB\u0414\u0430 \u043D\u0435,
    \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u043E\u0444\u043B\u2026\xBB\n\u0422\u044B
    \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0435\u0448\u044C \u0441\u0432\u0435\u0442
    \u0432 \u0434\u043E\u043C\u0435 \u0438 \u0443\u0431\u0435\u0433\u0430\u0435\u0448\u044C
    \u0432 \u043B\u0435\u0441"
