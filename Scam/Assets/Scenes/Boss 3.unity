  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\xAB\u041A\u043E\u043D\u0435\u0447\u043D\u043E! \u0412\u043E\u0442 \u0441\u043A\u0440\u0438\u043D\u0448\u043E\u0442\u044B
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432\u0438\u0440\u0443\u0441\u0430. \u0412\u0438\u0434\u0438\u0448\u044C?
    \u041C\u0430\u0440\u0448\u0440\u0443\u0442\u043A\u0430 \u044231 \u043F\u043E\u0435\u0445\u0430\u043B\u0430
    \u0432 \u043E\u0431\u0440\u0430\u0442\u043D\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443,
    \u0430 \u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0434\u0430\u0436\u0435
    \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B! \u0425\u043E\u0447\u0435\u0448\u044C
    \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C?\xBB\r\n\r\n\u0410\u043D\u043E\u043D\u0438\u043C
    (\u043F\u0440\u0438\u0449\u0443\u0440\u0438\u0432\u0448\u0438\u0441\u044C):\r\n\xAB\u0425\u043C\u2026
    \u0421\u043A\u0440\u0438\u043D\u0448\u043E\u0442\u044B \u0432\u044B\u0433\u043B\u044F\u0434\u044F\u0442
    \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E. \u041D\u043E
    \u044F \u0445\u0430\u043A\u0435\u0440, \u043C\u0435\u043D\u044F \u043D\u0435
    \u0442\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438.
    \u0427\u0442\u043E-\u0442\u043E \u0442\u0443\u0442 \u043D\u0435\u0447\u0438\u0441\u0442\u043E\u2026\xBB"
