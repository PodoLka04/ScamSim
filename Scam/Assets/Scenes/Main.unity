  m_text: "\u0417\u0434\u0435\u0441\u044C \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C
    \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044C \u043A\u043E\u0433\u043E \u0443\u0433\u043E\u0434\u043D\u043E:
    \u043E\u0442 \u0431\u0430\u0431\u0443\u043B\u0435\u043A \u0434\u043E \u0445\u0430\u043A\u0435\u0440\u043E\u0432.\r\n\u0421\u043C\u043E\u0436\u0435\u0448\u044C
    \u043B\u0438 \u0442\u044B \u0441\u0442\u0430\u0442\u044C \u043A\u043E\u0440\u043E\u043B\u0451\u043C
    \u0441\u043A\u0430\u043C\u0430? \u0412\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C!\r\n\r\nP.S.
    \u0412\u0441\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u044F \u0438 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0438
    \u0432\u044B\u043C\u044B\u0448\u043B\u0435\u043D\u044B, \u043D\u0438 \u043E\u0434\u043D\u0430
    \u0431\u0430\u0431\u0443\u0448\u043A\u0430 \u043D\u0435 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0430.\r\n\u0418\u0433\u0440\u0430
