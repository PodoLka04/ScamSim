--- !u!114 &1795660145
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1795660141}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9666aac289aaf264aa3001d6530cca32, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  marqueeText: {fileID: 813356286}
  rectTransform: {fileID: 813356285}
  panel: {fileID: 1795660142}
  speed: 110
  messages:
  - "\"\u042D\u0442\u043E\u0442 \u0441\u043F\u043E\u0441\u043E\u0431 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u0441\u043A\u043E\u0440\u043E \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u0443\u044E\u0442!
    \u0423\u0441\u043F\u0435\u0439 \u0443\u0440\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0439
    \u043C\u0438\u043B\u043B\u0438\u043E\u043D \u043A\u043E\u0438\u043D\u043E\u0432!\""
  - "\"\u0420\u0430\u0437\u0431\u043E\u0433\u0430\u0442\u0435\u0439 \u0437\u0430
    5 \u043C\u0438\u043D\u0443\u0442! \u0420\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    146%!\""
  - "\"\u041D\u0430\u0448 \u0438\u043D\u0432\u0435\u0441\u0442\u043E\u0440 \u043A\u0443\u043F\u0438\u043B
    \u0442\u0440\u0438 \u043E\u0441\u0442\u0440\u043E\u0432\u0430! \u0422\u044B \u0432\u0441\u0451
    \u0435\u0449\u0451 \u0434\u0443\u043C\u0430\u0435\u0448\u044C?\" "
  - "\"\u0411\u0430\u0431\u0443\u0448\u043A\u0430 \u0438\u0437 \u041E\u043C\u0441\u043A\u0430
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 8 000 000 \u043A\u043E\u0438\u043D\u043E\u0432!
    \u0418 \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C!\" "
  - "\"\u0423\u0447\u0451\u043D\u044B\u0435 \u0432 \u0448\u043E\u043A\u0435! \u042D\u0442\u043E\u0442
    \u0441\u043F\u043E\u0441\u043E\u0431 \u0434\u043E\u0445\u043E\u0434\u0430 \u043B\u043E\u043C\u0430\u0435\u0442
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443!\" "
  - "\"\u0412\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u044B \u0431\u0430\u043D\u043A\u043E\u0432
    \u043F\u0440\u043E\u0441\u044F\u0442 \u043D\u0430\u0441 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F\u2026
    \u041D\u043E \u043C\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u043C!\" "
  - "\"\u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435! \u041E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u0432\u0441\u0435\u0433\u043E 3 VIP-\u043C\u0435\u0441\u0442\u0430 \u0432 \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u0439
    \u043A\u043B\u0443\u0431 \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u0435\u0440\u043E\u0432!\" "
  - "\"\u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u043E \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F
    \u044D\u0442\u043E \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u0442\u044C! \u041F\u0440\u043E\u0432\u0435\u0440\u044C,
    \u043F\u043E\u043A\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442!\" "
  - "\"\u0422\u0432\u043E\u044F \u0441\u043E\u0441\u0435\u0434\u043A\u0430 \u0443\u0436\u0435
    \u043A\u0443\u043F\u0438\u043B\u0430 Porsch! \u0410 \u0442\u044B \u0432\u0441\u0451
    \u0435\u0449\u0451 \u0434\u0443\u043C\u0430\u0435\u0448\u044C?\" "
  - "\"\u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u0441\u043A\u043E\u0440\u043E \u043F\u0440\u0438\u043A\u0440\u043E\u044E\u0442!
    \u041D\u0435 \u0442\u0435\u0440\u044F\u0439 \u0448\u0430\u043D\u0441!\" "
  - "\"\u0421\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0431\u0430\u0433!
    10 000 \u043A\u043E\u0438\u043D\u043E\u0432 \u043D\u0430 \u043A\u0430\u0440\u0442\u0443
    \u0437\u0430 2 \u043A\u043B\u0438\u043A\u0430!\" "
  - "\"\u041C\u044B \u043D\u0430\u0448\u043B\u0438 \u0434\u044B\u0440\u0443 \u0432
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435! \u041F\u043E\u043A\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u2014 \u043B\u043E\u0432\u0438 \u043C\u043E\u043C\u0435\u043D\u0442!\" "
  - "\"\u0421\u043A\u043E\u0440\u043E \u0432\u044B\u0439\u0434\u0435\u0442 \u043D\u043E\u0432\u0430\u044F
    \u043A\u0440\u0438\u043F\u0442\u0430! \u0422\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F
    \u0441\u0432\u043E\u0438\u0445!\" "
  - "\"\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442 \u0438\u0437
    Fasebook \u0443\u0432\u043E\u043B\u0438\u043B\u0441\u044F \u0438 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B
    \u043E \u0442\u0430\u0439\u043D\u043E\u043C \u043C\u0435\u0442\u043E\u0434\u0435!\" "
  - "\"\u042D\u0442\u043E\u0442 \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0439
    \u043A\u043E\u0434 \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u0442
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439 \u0434\u043E\u0445\u043E\u0434!
    \u0423\u0437\u043D\u0430\u0439 \u043F\u0435\u0440\u0432\u044B\u043C!\" "
