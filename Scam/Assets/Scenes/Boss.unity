  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0422\u044B: \xAB\u0422\u0430\u043A \u0432\u043E\u0442 \u0432 \u0447\u0451\u043C
    \u0447\u0443\u0434\u043E! \u041C\u044B \u0432\u044B\u0431\u0440\u0430\u043B\u0438
    \u0432\u0430\u0441 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u043A\u0430\u043A \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u043E\u0433\u043E
    \u0432\u0435\u0442\u0435\u0440\u0430\u043D\u0430 \u0434\u0432\u043E\u0440\u043E\u0432\u044B\u0445
    \u0441\u043F\u043B\u0435\u0442\u0435\u043D. \u0414\u0435\u043D\u044C\u0433\u0438
    \u0443\u0436\u0435 \u0436\u0434\u0443\u0442 \u0432\u0430\u0441, \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u044C
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C!\xBB\n\n\u0411\u0430\u0431\u043A\u0430
    \u0417\u0438\u043D\u0430 (\u043F\u0440\u0438\u0449\u0443\u0440\u0438\u0432\u0448\u0438\u0441\u044C):
    \n\xAB\u0410 \u0432\u044B \u0447\u0430\u0441\u043E\u043C \u043D\u0435 \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u043A?
    \u0427\u0442\u043E-\u0442\u043E \u0443\u0436 \u0431\u043E\u043B\u044C\u043D\u043E
    \u0441\u043B\u0430\u0434\u043A\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0435\u2026\xBB"
  m_isRightToLeft: 0
