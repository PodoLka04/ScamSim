  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\t         \u041D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F
    \u0431\u0438\u0442\u0432\u0430!\n\u0422\u0432\u043E\u044F \u0437\u0430\u0434\u0430\u0447\u0430
    \u2014 \u043F\u0435\u0440\u0435\u043A\u043B\u0438\u043A\u0430\u0442\u044C \u0431\u0430\u0431\u043A\u0443,
    \u043F\u043E\u043A\u0430 \u043E\u043D\u0430 \u043D\u0435 \u0437\u0430\u043F\u043E\u0434\u043E\u0437\u0440\u0438\u043B\u0430
    \u043D\u0435\u043B\u0430\u0434\u043D\u043E\u0435.\n\n\t\t\t\u0428\u043A\u0430\u043B\u044B:\n\u0428\u043A\u0430\u043B\u0430
    \u0440\u0430\u0437\u0432\u043E\u0434\u0430 (\u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0435\u0448\u044C
    \u043A\u043B\u0438\u043A\u0430\u043C\u0438)\n\u0428\u043A\u0430\u043B\u0430 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u044F
    (\u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u2013 \u0447\u0435\u043C \u0434\u043E\u043B\u044C\u0448\u0435 \u0442\u044F\u043D\u0435\u0448\u044C,
    \u0442\u0435\u043C \u0431\u043B\u0438\u0436\u0435 \u043A \u043F\u0440\u043E\u0432\u0430\u043B\u0443)\n\n\t\t        
    \u0422\u0430\u043A\u0442\u0438\u043A\u0430:\n\u0422\u044B \u043A\u043B\u0438\u043A\u0430\u0435\u0448\u044C,
    \u0443\u0431\u0435\u0436\u0434\u0430\u044F \u0435\u0451, \u043F\u043E\u043A\u0430
    \u043E\u043D\u0430 \u043D\u0435 \u0441\u0434\u0430\u0451\u0442\u0441\u044F. \u0415\u0441\u043B\u0438
    \u0448\u043A\u0430\u043B\u0430 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u044F
    \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u0441\u044F \u0440\u0430\u043D\u044C\u0448\u0435
    \u2014 \u0431\u0430\u0431\u043A\u0430 \u0440\u0430\u0437\u043E\u0437\u043B\u0438\u0442\u0441\u044F,
    \u043D\u0430\u0436\u043C\u0451\u0442 \u043D\u0430 \u0442\u0440\u0435\u0432\u043E\u0436\u043D\u0443\u044E
    \u043A\u043D\u043E\u043F\u043A\u0443 \u0438 \u0432\u044B\u0437\u043E\u0432\u0435\u0442
    \u043F\u043E\u043B\u0438\u0446\u0438\u044E! "
  m_isRightToLeft: 0
