  m_text: "\u0422\u044B: \xAB3\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
    \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u0430\u044F! \u0412\u044B \u043D\u0435
    \u043F\u043E\u0432\u0435\u0440\u0438\u0442\u0435, \u043D\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0442\u043E \u0432\u0430\u0448\u0430 \u0444\u0430\u043C\u0438\u043B\u0438\u044F
    \u0432\u044B\u043F\u0430\u043B\u0430 \u0432 \u0440\u043E\u0437\u044B\u0433\u0440\u044B\u0448\u0435
    \u0441\u0440\u0435\u0434\u0438 \u043F\u0435\u043D\u0441\u0438\u043E\u043D\u0435\u0440\u043E\u0432,
    \u0438 \u0432\u044B \u0432\u044B\u0438\u0433\u0440\u0430\u043B\u0438 100 000
    \u043A\u043E\u0438\u043D\u043E\u0432!\xBB\n\n\u0411\u0430\u0431\u043A\u0430 \u0417\u0438\u043D\u0430:
    \xAB\u0414\u0430 \u043D\u0443! A \u044F \u0432\u0435\u0434\u044C \u0438 \u043D\u0435
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430\u2026\xBB"
