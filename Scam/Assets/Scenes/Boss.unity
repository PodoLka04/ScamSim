  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0411\u0430\u0431\u043A\u0430 \u0417\u0438\u043D\u0430 (\u0437\u043B\u043E\u0431\u043D\u043E
    \u0448\u0438\u043F\u0438\u0442, \u0441\u0436\u0438\u043C\u0430\u044F \u0442\u0435\u043B\u0435\u0444\u043E\u043D
    \u0432 \u043A\u043E\u0433\u0442\u0438\u0441\u0442\u044B\u0445 \u043F\u0430\u043B\u044C\u0446\u0430\u0445):\n\u2014
    \u0425\u0430! \u0412\u043E\u0442 \u0434\u0443\u0440\u0430\u043A\u0438! \u0412\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C \u043C\u0435\u043D\u044F \u043E\u0431\u0431\u0438\u0440\u0430\u043B\u0438,
    \u0430 \u0442\u0435\u043F\u0435\u0440\u044C \u044F \u0412\u0421\u0401 \u0443
    \u043D\u0438\u0445 \u0437\u0430\u0431\u0435\u0440\u0443! \u0425\u0430\u0445\u0430\u0445\u0430!
    \u0414\u0430\u0432\u0430\u0439, \u043C\u0430\u043B\u0435\u0446, \u043E\u0444\u043E\u0440\u043C\u043B\u044F\u0439,
    \u0447\u0442\u043E\u0431 \u043C\u043E\u0439 \u0432\u043E\u043D\u044E\u0447\u0438\u0439
    \u0432\u043D\u0443\u0447\u043E\u043A \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5c8d5ee85ccc79342bf9aaf63152545a, type: 2}
