  m_text: "\u0411\u0430\u0431\u043A\u0430 \u0417\u0438\u043D\u0430:\n\u2014 \u0410\u0445
    \u0442\u044B, \u0436\u0443\u043B\u0438\u043A! \u0414\u0443\u043C\u0430\u0435\u0448\u044C,
    \u044F \u0441\u0442\u0430\u0440\u0430\u044F, \u0437\u043D\u0430\u0447\u0438\u0442,
    \u0433\u043B\u0443\u043F\u0430\u044F? \u0421\u0435\u0439\u0447\u0430\u0441 \u0432\u043D\u0443\u0447\u043A\u0443
    \u043F\u043E\u0437\u043E\u0432\u0443, \u043E\u043D \u0443 \u043C\u0435\u043D\u044F
    \u0432 \u043A\u0438\u0431\u0435\u0440\u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442!\n\n\u0422\u044B (\u0432 \u043F\u0430\u043D\u0438\u043A\u0435):\n\u2014
    \u0414\u0430 \u043D\u0435, \u0431\u0430\u0431\u0443\u043B\u044C, \u044D\u0442\u043E
    \u0448\u0443\u0442\u043A\u0430 \u0431\u044B\u043B\u0430\u2026\n\u0422\u044B \u0441\u043B\u044B\u0448\u0438\u0448\u044C
    \u0441\u0438\u0440\u0435\u043D\u0443 \u2014 \u0431\u0430\u0431\u043A\u0430 \u0443\u0436\u0435
    \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u043F\u043E\u043B\u0438\u0446\u0438\u044E!
    \u0422\u044B \u0441\u043F\u0430\u0441\u0430\u0435\u0448\u044C\u0441\u044F \u0431\u0435\u0433\u0441\u0442\u0432\u043E\u043C! "
