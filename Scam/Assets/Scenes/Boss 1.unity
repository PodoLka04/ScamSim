  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0414\u0438\u043C\u0430\u043D:\r\n\xAB\u0410\u0445 \u0442\u044B, \u0436\u0443\u043B\u0438\u043A!
    \u0414\u0443\u043C\u0430\u0435\u0448\u044C, \u044F \u043D\u0443\u0431\u0438\u043A,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0430 \u0442\u0430\u043A\u043E\u0435 \u0432\u0435\u0441\u0442\u0438\u0441\u044C?
    \u0421\u0435\u0439\u0447\u0430\u0441 \u044F \u043F\u043E\u0437\u043E\u0432\u0443
    \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u043E\u0440\u0435\u0448\u0430 \u041A\u043E\u0441\u0442\u044F\u043D\u0430,
    \u043E\u043D \u0443 \u043C\u0435\u043D\u044F \u0432 \u043A\u0438\u0431\u0435\u0440\u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438
    \u0448\u0430\u0440\u0438\u0442! \u0410 \u0435\u0449\u0435 \u0416\u0435\u043A\u0438\u0447
    \u0443 \u043C\u0435\u043D\u044F \u044E\u0440\u0438\u0441\u0442! \u0422\u0435\u0431\u0435
    \u043A\u043E\u043D\u0435\u0446!\xBB\n\n\u0422\u044B: \xAB\u041E\u0442\u043A\u043B\u044E\u0447\u0430\u0435\u0448\u044C
    \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442 \u0438 \u043F\u0440\u044F\u0447\u0435\u0448\u044C\u0441\u044F
    \u043F\u043E\u0434 \u043A\u0440\u043E\u0432\u0430\u0442\u044C\xBB"
