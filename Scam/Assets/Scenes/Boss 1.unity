  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0414\u0438\u043C\u0430\u043D (\u0437\u043B\u043E\u0431\u043D\u043E \u0443\u0445\u043C\u044B\u043B\u044F\u044F\u0441\u044C):\r\n\xAB\u0425\u0430!
    \u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E \u044F \u043F\u043E\u043B\u0443\u0447\u0443
    \u044D\u0442\u0438 \u0441\u043A\u0438\u043D\u044B! \u0410 \u0442\u043E \u043C\u043E\u0439
    \u043A\u043E\u0440\u0435\u0448 \u0412\u0430\u0441\u044C\u043A\u0430 \u0432\u0441\u0451
    \u0445\u0432\u0430\u0441\u0442\u0430\u043B\u0441\u044F \u0441\u0432\u043E\u0438\u043C\u0438.
    \u0422\u0435\u043F\u0435\u0440\u044C \u044F \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u043A\u043B\u0438\u043A\u0430\u044E!
    \u0414\u0430\u0432\u0430\u0439, \u043E\u0444\u043E\u0440\u043C\u043B\u044F\u0439,
    \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u044B\u0441\u0442\u0440\u0435\u0435,
    \u0430 \u0442\u043E \u0443 \u043C\u0435\u043D\u044F \u043B\u0430\u0431\u0430
    \u043F\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u0433\u043E\u0440\u0438\u0442!\xBB"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5c8d5ee85ccc79342bf9aaf63152545a, type: 2}
