      m_Calls: []
  m_text: "\u0422\u044B:\r\n\xAB\u042D\u0439, \u0414\u0438\u043C\u0430\u043D! \u0422\u044B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u0432\u044B\u0438\u0433\u0440\u0430\u043B
    \u0442\u043E\u043F\u043E\u0432\u044B\u0435 \u0441\u043A\u0438\u043D\u044B \u0434\u043B\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u043E\u0433\u043E
    \u0448\u0443\u0442\u0435\u0440\u0430! \u042D\u0442\u043E \u044D\u043A\u0441\u043A\u043B\u044E\u0437\u0438\u0432\u043D\u0430\u044F
    \u0430\u043A\u0446\u0438\u044F \u0434\u043B\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432,
    \u0438 \u0442\u044B \u2014 \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u0447\u0438\u043A!\xBB\r\n\r\n\u0414\u0438\u043C\u0430\u043D:\r\n\xAB\u0427\u0451?
    \u042F? \u0412\u044B\u0438\u0433\u0440\u0430\u043B? \u0410 \u044F \u0434\u0430\u0436\u0435
    \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u043D\u0438
    \u0432 \u043A\u0430\u043A\u0438\u0445 \u0430\u043A\u0446\u0438\u044F\u0445\u2026\xBB"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5c8d5ee85ccc79342bf9aaf63152545a, type: 2}
