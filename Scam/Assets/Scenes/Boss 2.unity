  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0422\u044B:\r\n\xAB\u0413\u0430\u0440\u0430\u043D\u0442\u0438\u0438?
    \u041A\u043E\u043D\u0435\u0447\u043D\u043E! \u0423 \u043D\u0430\u0441 \u0443\u0436\u0435
    \u0435\u0441\u0442\u044C \u0438\u043D\u0432\u0435\u0441\u0442\u043E\u0440\u044B
    \u0438\u0437 \u041A\u0440\u0435\u043C\u043D\u0438\u0435\u0432\u043E\u0439 \u0434\u043E\u043B\u0438\u043D\u044B,
    \u0438 \u043C\u044B \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B\u0438 \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442\u044B
    \u0441 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u043C\u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438
    \u0440\u0435\u0437\u0438\u043D\u044B. \u0412\u043E\u0442 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B,
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0449\u0438\u0435
    \u043D\u0430\u0448\u0443 \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0441\u0442\u044C.\xBB\r\n\r\n\u0415\u0432\u0433\u0435\u043D
    (\u043F\u0440\u0438\u0449\u0443\u0440\u0438\u0432\u0448\u0438\u0441\u044C):\r\n\xAB\u0425\u043C\u2026
    \u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u0432\u044B\u0433\u043B\u044F\u0434\u044F\u0442
    \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E. \u041D\u043E
    \u044F \u044E\u0440\u0438\u0441\u0442, \u043C\u0435\u043D\u044F \u043D\u0435
    \u0442\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438.
    \u0427\u0442\u043E-\u0442\u043E \u0442\u0443\u0442 \u043D\u0435\u0447\u0438\u0441\u0442\u043E\u2026\xBB"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5c8d5ee85ccc79342bf9aaf63152545a, type: 2}
